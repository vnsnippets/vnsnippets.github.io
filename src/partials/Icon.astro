---
// src/components/Icon.astro
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"svg"> {
  name: string;
}

const { name, ...props } = Astro.props;

const icons = import.meta.glob<{ default: string }>("/src/assets/vectors/*.svg", { query: "?raw", eager: true });
const iconPath = `/src/assets/vectors/${name}.svg`;
const icon = icons[iconPath];
const rawSvg = icon?.default;

if (!rawSvg) {
  throw new Error(`Icon "${name}" not found in /src/assets/vectors`);
}

// 1. Extract just the inner contents of the SVG
const svgInnerContent = rawSvg.replace(/^<svg[^>]*>/, "").replace(/<\/svg>$/, "");

// 2. Extract the original opening tag attributes string
const match = rawSvg.match(/^<svg([^>]*)>/);
const attrString = match ? match[1] : "";

// 3. Parse that string into a proper key-value object
const originalAttrs: Record<string, string> = {};
const attrRegex = /([\w-]+)\s*=\s*[""]([^""]*)[""]/g;
let attrMatch;

while ((attrMatch = attrRegex.exec(attrString)) !== null) {
  const [, key, value] = attrMatch;
  originalAttrs[key] = value;
}

// 4. Merge them: incoming props override the original SVG"s default attributes
const mergedProps = { ...originalAttrs, ...props };
---

<svg {...mergedProps} set:html={svgInnerContent} />