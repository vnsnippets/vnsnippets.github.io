---
import type { CollectionTypes } from "../types";
import { SiteSettings, ToShortDate } from "../utilities";
import TagsPartialAstroComponent from "./TagsPartial.astro";

type Props = CollectionTypes.Article;
const article = Astro.props;

const getArticlePath = (id: string) => `/articles/${id}`;
---

<a
    href={getArticlePath(article.id)}
    class="relative shadow-lg rounded-md hover:rounded-xl overflow-hidden border border-mocha-overlay bg-mocha-surface hover:bg-mocha-mantle transition-all duration-200 ease-in-out group"
>
    <div class="relative size-full grid grid-rows-[auto_auto_1fr] gap-2 p-6">        
        <p class="uppercase text-mocha-subtext font-semibold text-base">
            {article.data.Series ?? SiteSettings.Articles.DefaultSeries}
        </p>

        <div class="grid gap-2">
            <p class="text-base text-mocha-text font-semibold">{article.data.Title}</p>
            {article.data.Cover ? (
                <div class="relative w-full min-h-40 my-2">
                    <div class="absolute w-full h-full overflow-hidden rounded">
                        <img src={article.data.Cover} alt=`Cover image for ${article.data.Title}` class="w-full h-full object-cover" />
                        <div class="absolute inset-0 bg-mocha-crust opacity-0 group-hover:opacity-80 transition-opacity duration-200 ease-in-out" />
                    </div>
                    <p class="text-base p-4 w-full h-full flex items-end text-mocha-caption opacity-0 translate-y-5 group-hover:opacity-100 group-hover:translate-y-0 transform transition-all duration-200 ease-in-out">{article.data.Caption}</p>
                </div>
            ) : (
                <p class="text-base opacity-100 text-mocha-caption">{article.data.Caption}</p>
            )}
        </div>

        <div class="flex flex-col justify-end gap-4">
        <TagsPartialAstroComponent Tags={article.data.Tags} />
            <div class="flex justify-between items-end gap-2 text-mocha-subtext">
                <p class="text-base">{ToShortDate(article.data.Published)}</p>
            </div>
        </div>
    </div>
</a>
