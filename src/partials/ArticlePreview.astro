---
import type { CollectionTypes } from "../types";
import ArticleCardWithCover from "./ArticleCardWithCover.astro";
import ArticleCardWithText from "./ArticleCardWithText.astro";

type Props = CollectionTypes.Article;
const article = Astro.props;
---

{
  article.data.Cover ? (
    <ArticleCardWithCover {...article} />
  ) : (
    <ArticleCardWithText {...article} />
  )
}