---
import { getCollection } from "astro:content";
import type { CollectionTypes } from "../../../types";
import { FilterDraftsOnProduction, SiteSettings, Slugify } from "../../../utilities";
import ArticlePreview from "Partials:/ArticlePreview.astro";
import NavigationLayout from "Views:/NavigationLayout.astro";

// 1. Generate paths for each unique tag in your articles
// src/pages/articles/tags/[tag].astro
export async function getStaticPaths() {
    const articles = await getCollection("Articles", FilterDraftsOnProduction);

    // 1. Gather all unique slugified tags
    const uniqueSlugs = [
        ...new Set(
            articles
                .flatMap((article) => article.data.Tags || [])
                .map((t) => Slugify(t))
        ),
    ];

    return uniqueSlugs.map((slug) => {
        // 2. Filter articles where any tag matches the current slug
        const taggedArticles = articles.filter(
            (article) =>
                article.data.Tags &&
                article.data.Tags.some((t) => Slugify(t) === slug)
        );

        // Find the original casing (with spaces intact) for display headers
        const originalTag =
            articles
                .flatMap((a) => a.data.Tags || [])
                .find((t) => Slugify(t) === slug) || slug;

        return {
            params: { tag: slug },
            props: {
                tagName: originalTag, // Retains spaces and casing, e.g. "Web Development"
                articles: taggedArticles,
            },
        };
    });
}

const DEVMODE = import.meta.env.DEV;
const { tagName, articles } = Astro.props;

// 2. Separate published articles and drafts (just like your main listing page)
type ReducedListType = {
    drafts: CollectionTypes.Article[];
    published: CollectionTypes.Article[];
};

const groupedArticles = articles
    .sort((a, b) => b.data.Published.getTime() - a.data.Published.getTime())
    .reduce<ReducedListType>(
        (result, e) => {
            if (e.data.Draft) result.drafts.push(e);
            else result.published.push(e);
            return result;
        },
        { drafts: [], published: [] },
    );
---

<NavigationLayout Title={`${SiteSettings.SiteName} :: Tags : ${tagName}`} Hidden={true}>
    <div class="grid gap-2 max-w-xl mx-auto text-center mt-12" slot="pre-navigation" >
        <h1 class="text-xl text-mocha-text">
            {`${SiteSettings.Articles.TagPageTitle} :: ${tagName}`}
        </h1>
    </div>

    <div class="grid md:grid-cols-2 xl:grid-cols-3 gap-4">
        {groupedArticles.published.map((e: CollectionTypes.Article) => {
                return <ArticlePreview {...e} />;
        })}
    </div>

    {DEVMODE && groupedArticles.drafts.length > 0 && (
        <div class="mt-12 pt-12">
            <p class="text-mocha-text mb-4">
                DRAFTS TAGGED "{tagName.toUpperCase()}" (DEV MODE)
            </p>
            <div class="grid md:grid-cols-2 xl:grid-cols-3 gap-4">
                {groupedArticles.drafts.map(
                    (e: CollectionTypes.Article) => {
                        return <ArticlePreview {...e} />;
                    },
                )}
            </div>
        </div>
    )}
</NavigationLayout>
