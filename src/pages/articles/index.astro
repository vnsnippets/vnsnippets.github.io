---
import { getCollection } from "astro:content";

import ArticlePreview from "Partials:/ArticlePreview.astro";
import NavigationLayout from "Views:/NavigationLayout.astro";

import { FilterDraftsOnProduction, GetPageProperties } from "../../utilities";
import type { CollectionTypes } from "../../types";

const { Metadata: pagemetadata, ...otherprops} = GetPageProperties(Astro.url.pathname);

const articles = (await getCollection("Articles", FilterDraftsOnProduction))
    .sort((a, b) => b.data.Published.getTime() - a.data.Published.getTime());

const calculategridclass = (index: number) => {
  const patternIndex = index % 10;
  if (patternIndex === 0 || patternIndex === 5) {
    return "lg:col-span-2";
  }
  return "lg:col-span-1";
};
---

<NavigationLayout {...pagemetadata} containerstyles="container">
    <div class="grid gap-2 max-w-xl mx-auto text-center mt-12 mb-12" slot="pre-navigation">
        <h1 class="text-xl font-bold text-mocha-text">{pagemetadata.Title}</h1>
        <p class="text-base text-mocha-caption">{pagemetadata.Description}</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 xl:grid-cols-4 gap-6">
        {articles.map((e: CollectionTypes.Article, index: number) => {
            return <ArticlePreview {...e} grid={calculategridclass(index)} />;
        })}
    </div>
</NavigationLayout>