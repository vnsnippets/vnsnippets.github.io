---
// src/pages/articles/[year]/[slug].astro
import { getCollection, render } from "astro:content";
import ArticleLayout from "Views:/ArticleLayout.astro";
import { FilterDraftsOnProduction } from "../../../utilities";

export async function getStaticPaths() {
    // Filter out drafts during production builds so their URLs are never compiled
    const articles = await getCollection("Articles", FilterDraftsOnProduction);
    
    return articles.map(entry => {
        const pathParts = entry.id.split("/"); 
        const year = pathParts[0];
        const slug = pathParts[1].replace(/\.[^/.]+$/, ""); 

        return {
            params: { year, slug },
            props: { entry },
        };
    });
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<ArticleLayout {...entry}>
    <Content />
</ArticleLayout>