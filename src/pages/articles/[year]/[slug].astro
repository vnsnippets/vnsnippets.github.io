---
// src/pages/articles/[year]/[slug].astro
import { getCollection, render } from "astro:content";
import ArticleSingleView from "Views:/ArticleSingleView.astro";
import { FilterDraftsOnProduction } from "../../../utilities";

export async function getStaticPaths() {
    const articles = await getCollection("Articles", FilterDraftsOnProduction);
    
    // Sort chronologically (oldest to newest) once before mapping
    const sorted = articles.sort(
        (a, b) => a.data.Published.getTime() - b.data.Published.getTime()
    );

    return sorted.map((entry, index) => {
        const pathParts = entry.id.split("/"); 
        const year = pathParts[0];
        const slug = pathParts[1].replace(/\.[^/.]+$/, ""); 

        // Extract neighboring objects safely if they exist
        const prev = index > 0 ? sorted[index - 1] : null;
        const next = index < sorted.length - 1 ? sorted[index + 1] : null;

        return {
            params: { year, slug },
            props: { entry, prev, next },
        };
    });
}

const { entry, prev, next } = Astro.props;
const { Content } = await render(entry);
---

<ArticleSingleView Current={entry} Previous={prev} Next={next}>
    <Content />
</ArticleSingleView>