---
import NavigationLayout from "Views:/NavigationLayout.astro";
import IconAstroComponent from "Partials:/Icon.astro";

import { GetPageProperties } from "../utilities";

const PageProperties = GetPageProperties(Astro.url.pathname);
---

<NavigationLayout {...PageProperties.Metadata} Title={PageProperties.Metadata.Title}>
    <div class="grid gap-2 max-w-xl mx-auto text-center mt-4 lg:mt-12" slot="pre-navigation">
        <div class="mb-8 lg:mb-12 max-w-96 px-6 md:px-12 mx-auto">
            <IconAstroComponent class="w-full h-full" name="island-night" />
        </div>
        <h1 class="text-xl text-mocha-text">{PageProperties.Metadata.Title}</h1>
        <p class="text-base text-mocha-subtext">{PageProperties.Metadata.Description}</p>
    </div>
</NavigationLayout>