{
    "extends": "astro/tsconfigs/strict",
    "include": [
        ".astro/types.d.ts",
        "**/*"
    ],
    "exclude": [
        "dist"
    ],
    "compilerOptions": {
        "paths": {
            "Views:/*": ["./src/views/*"],
            "Partials:/*": ["./src/partials/*"],
            "Assets:/*": ["./src/assets/*"], 
            "Content:/*": ["./content/*"], 
        }
    }
}